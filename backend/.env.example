PORT=3001
# 前端页面 origin（浏览器地址），例如 Next dev 默认 :3000。不要用后端 :3001 填写在这里。
PO1MARKET_CORS_ORIGIN=http://localhost:3000
PO1MARKET_POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
PO1MARKET_REQUEST_TIMEOUT_SECONDS=15
PO1MARKET_GOOGLE_NEWS_BASE_URL=https://news.google.com/rss/search
PO1MARKET_REDDIT_SEARCH_BASE_URL=https://www.reddit.com/search.json
PO1MARKET_USER_AGENT=po1market/0.1 (+https://github.com/your-org/po1market)
PO1MARKET_OPENAI_API_KEY=
PO1MARKET_OPENAI_BASE_URL=https://api.openai.com/v1
PO1MARKET_OPENAI_MODEL=gpt-4.1-mini
# Query planning (LLM-first); if set, takes priority over OpenAI for query generation only.
PO1MARKET_DEEPSEEK_API_KEY=
PO1MARKET_DEEPSEEK_BASE_URL=https://api.deepseek.com
PO1MARKET_DEEPSEEK_MODEL=deepseek-v4-flash
# Planner 等非密钥诊断（超时/HTTP 状态/空回复等）；为 true 时会在终端输出
PO1MARKET_QUERY_DEBUG=false
PO1MARKET_LLM_RERANK_ENABLED=false
PO1MARKET_MARKET_DEFAULT_LIMIT=8
PO1MARKET_MARKET_CANDIDATE_LIMIT=20
